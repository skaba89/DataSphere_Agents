+import os
+import json
+from typing import Optional, AsyncGenerator
+from openai import OpenAI
+
+OPENAI_API_KEY = os.getenv("OPENAI_API_KEY", "")
+OPENAI_MODEL = os.getenv("OPENAI_MODEL", "gpt-3.5-turbo")
+GROQ_API_KEY = os.getenv("GROQ_API_KEY", "")
+GROQ_MODEL = os.getenv("GROQ_MODEL", "mixtral-8x7b-32768")
+
+
+def get_ai_client() -> tuple:
+    if OPENAI_API_KEY:
+        return OpenAI(api_key=OPENAI_API_KEY), OPENAI_MODEL
+    if GROQ_API_KEY:
+        return OpenAI(api_key=GROQ_API_KEY, base_url="https://api.groq.com/openai/v1"), GROQ_MODEL
+    return None, None
+
+
+def generate_demo_response(agent_name: str, message: str) -> str:
+    return (
+        f"👋 Bonjour ! Je suis **{agent_name}**.\n\n"
+        f"J'ai bien reçu votre message : *\"{message[:100]}{'...' if len(message) > 100 else ''}\"*\n\n"
+        f"---\n\n"
+        f"⚠️ **Mode démo** : Aucun fournisseur IA n'est configuré pour le moment.\n\n"
+        f"Pour activer mes capacités complètes, configurez une clé API :\n\n"
+        f"1. **OpenAI** : Ajoutez `OPENAI_API_KEY` dans le fichier `.env`\n"
+        f"2. **Groq** : Ajoutez `GROQ_API_KEY` dans le fichier `.env`\n\n"
+        f"Une fois configuré, je pourrai vous fournir des réponses personnalisées et professionnelles !"
+    )
+
+
+async def stream_ai_response(system_prompt: str, messages: list, agent_name: str) -> AsyncGenerator[str, None]:
+    client, model = get_ai_client()
+
+    if client is None:
+        demo_text = generate_demo_response(agent_name, messages[-1]["content"] if messages else "")
+        words = demo_text.split(" ")
+        for i, word in enumerate(words):
+            chunk = word if i == 0 else " " + word
+            yield json.dumps({"content": chunk})
+        yield "[DONE]"
+        return
+
+    try:
+        all_messages = [{"role": "system", "content": system_prompt}] + messages
+        stream = client.chat.completions.create(
+            model=model,
+            messages=all_messages,
+            stream=True,
+            temperature=0.7,
+            max_tokens=2048,
+        )
+        for chunk in stream:
+            if chunk.choices and chunk.choices[0].delta.content:
+                yield json.dumps({"content": chunk.choices[0].delta.content})
+        yield "[DONE]"
+    except Exception as e:
+        error_msg = f"Erreur lors de la génération de la réponse : {str(e)}"
+        yield json.dumps({"content": f"\n\n❌ {error_msg}"})
+        yield "[DONE]"
+
+
+def generate_ai_response(system_prompt: str, messages: list, agent_name: str) -> str:
+    client, model = get_ai_client()
+    if client is None:
+        return generate_demo_response(agent_name, messages[-1]["content"] if messages else "")
+    try:
+        all_messages = [{"role": "system", "content": system_prompt}] + messages
+        response = client.chat.completions.create(
+            model=model,
+            messages=all_messages,
+            temperature=0.7,
+            max_tokens=2048,
+        )
+        return response.choices[0].message.content
+    except Exception as e:
+        return f"❌ Erreur lors de la génération : {str(e)}"
