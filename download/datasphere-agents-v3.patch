+          initial={{ opacity: 0 }}
+          animate={{ opacity: 1 }}
+        >
+          <motion.span
+            className="w-1.5 h-1.5 rounded-full bg-emerald-500"
+            animate={{ y: [0, -4, 0] }}
+            transition={{ duration: 0.6, repeat: Infinity, delay: 0 }}
+          />
+          <motion.span
+            className="w-1.5 h-1.5 rounded-full bg-emerald-500"
+            animate={{ y: [0, -4, 0] }}
