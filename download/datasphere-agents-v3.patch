+            title: 'Transactions réussies',
+            value: successCount,
+            icon: CheckCircle2,
+            gradient: 'from-amber-500 to-orange-600',
+            bg: 'bg-amber-50 dark:bg-amber-950/50',
+          },
+          {
+            title: 'En attente',
+            value: pendingCount,
+            icon: Clock,
+            gradient: 'from-violet-500 to-purple-600',
+            bg: 'bg-violet-50 dark:bg-violet-950/50',
+          },
+        ].map((stat, i) => {
+          const Icon = stat.icon;
+          return (
