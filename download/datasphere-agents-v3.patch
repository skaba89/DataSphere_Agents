new file mode 100644
index 0000000..712a677
--- /dev/null
+++ b/datasphere_agents/frontend/store/useStore.ts
@@ -0,0 +1,82 @@
+import { create } from 'zustand';
+import { API_URL } from '../lib/api';
+
+interface User { id:number; email:string; username:string; full_name:string; role:string; avatar:string; is_active:boolean; }
+interface Agent { id:number; agent_id:string; name:string; description:string; icon:string; category:string; color:string; is_active:boolean; }
+interface Conversation { id:number; title:string; agent_id:string; created_at:string; updated_at:string; }
+interface Message { id:number; role:string; content:string; created_at:string; }
+
+interface AppState {
+  user: User|null; token: string|null; isAuthenticated: boolean;
+  agents: Agent[]; selectedAgent: Agent|null;
+  conversations: Conversation[]; currentConversation: Conversation|null; messages: Message[]; isStreaming: boolean;
+  sidebarOpen: boolean; currentView: 'dashboard'|'agents'|'chat'|'settings'; mobileMenuOpen: boolean;
+  login: (email:string, password:string) => Promise<void>;
+  register: (email:string, password:string, username:string, fullName:string) => Promise<void>;
+  logout: () => void; loadUser: () => Promise<void>;
+  fetchAgents: () => Promise<void>; selectAgent: (agent:Agent) => void;
+  fetchConversations: (agentId:string) => Promise<void>;
+  setConversation: (conv:Conversation|null) => void;
+  fetchMessages: (convId:number) => Promise<void>;
+  sendMessage: (content:string) => Promise<void>;
+  setSidebarOpen: (open:boolean) => void;
+  setCurrentView: (view:'dashboard'|'agents'|'chat'|'settings') => void;
+  setMobileMenuOpen: (open:boolean) => void;
+}
+
+export const useStore = create<AppState>((set, get) => ({
+  user: typeof window!=='undefined' ? JSON.parse(localStorage.getItem('user')||'null') : null,
+  token: typeof window!=='undefined' ? localStorage.getItem('token') : null,
+  isAuthenticated: typeof window!=='undefined' ? !!localStorage.getItem('token') : false,
+  agents: [], selectedAgent: null,
+  conversations: [], currentConversation: null, messages: [], isStreaming: false,
+  sidebarOpen: true, currentView: 'dashboard', mobileMenuOpen: false,
+
+  login: async (email, password) => {
+    const res = await fetch(`${API_URL}/api/auth/login`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({email,password}) });
+    if (!res.ok) { const d=await res.json().catch(()=>({})); throw new Error(d.detail||'Erreur de connexion'); }
+    const data=await res.json();
+    localStorage.setItem('token',data.access_token); localStorage.setItem('user',JSON.stringify(data.user));
+    set({user:data.user,token:data.access_token,isAuthenticated:true});
+  },
+  register: async (email,password,username,fullName) => {
+    const res = await fetch(`${API_URL}/api/auth/register`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({email,password,username,full_name:fullName}) });
+    if (!res.ok) { const d=await res.json().catch(()=>({})); throw new Error(d.detail||"Erreur d'inscription"); }
+    const data=await res.json();
+    localStorage.setItem('token',data.access_token); localStorage.setItem('user',JSON.stringify(data.user));
+    set({user:data.user,token:data.access_token,isAuthenticated:true});
+  },
+  logout: () => { localStorage.removeItem('token'); localStorage.removeItem('user'); set({user:null,token:null,isAuthenticated:false,agents:[],selectedAgent:null,conversations:[],messages:[]}); },
+  loadUser: async () => { const t=localStorage.getItem('token'); if(!t)return; try { const r=await fetch(`${API_URL}/api/auth/me`,{headers:{Authorization:`Bearer ${t}`}}); if(r.ok){const u=await r.json();localStorage.setItem('user',JSON.stringify(u));set({user:u,isAuthenticated:true});}else get().logout(); } catch{get().logout();} },
+
+  fetchAgents: async () => { const t=localStorage.getItem('token'); if(!t)return; const r=await fetch(`${API_URL}/api/agents`,{headers:{Authorization:`Bearer ${t}`}}); if(r.ok) set({agents:await r.json()}); },
+  selectAgent: (agent) => { set({selectedAgent:agent,messages:[],currentConversation:null}); get().fetchConversations(agent.agent_id); get().setCurrentView('chat'); },
+
+  fetchConversations: async (agentId) => { const t=localStorage.getItem('token'); if(!t)return; try { const r=await fetch(`${API_URL}/api/agents/${agentId}/conversations`,{headers:{Authorization:`Bearer ${t}`}}); if(r.ok) set({conversations:await r.json()}); } catch{} },
+  setConversation: (conv) => { set({currentConversation:conv,messages:[]}); if(conv) get().fetchMessages(conv.id); },
+  fetchMessages: async (convId) => { const t=localStorage.getItem('token'); if(!t)return; try { const r=await fetch(`${API_URL}/api/agents/conversations/${convId}/messages`,{headers:{Authorization:`Bearer ${t}`}}); if(r.ok) set({messages:await r.json()}); } catch{} },
+
+  sendMessage: async (content) => {
+    const {selectedAgent,currentConversation,token}=get(); if(!selectedAgent||!token||!content.trim())return;
+    const userMsg:Message={id:Date.now(),role:'user',content,created_at:new Date().toISOString()};
+    set(s=>({messages:[...s.messages,userMsg],isStreaming:true}));
+    try {
+      const res=await fetch(`${API_URL}/api/agents/${selectedAgent.agent_id}/chat`,{method:'POST',headers:{'Content-Type':'application/json',Authorization:`Bearer ${token}`},body:JSON.stringify({message:content,conversation_id:currentConversation?.id||null})});
+      if(!res.ok) throw new Error('Failed');
+      const convId=res.headers.get('X-Conversation-Id');
+      if(convId&&!currentConversation){const c:Conversation={id:parseInt(convId),title:content.slice(0,50),agent_id:selectedAgent.agent_id,created_at:new Date().toISOString(),updated_at:new Date().toISOString()};set({currentConversation:c});get().fetchConversations(selectedAgent.agent_id);}
+      const reader=res.body?.getReader(); if(!reader) throw new Error('No reader');
+      const decoder=new TextDecoder(); let assistantContent='';
+      const assistantMsg:Message={id:Date.now()+1,role:'assistant',content:'',created_at:new Date().toISOString()};
+      set(s=>({messages:[...s.messages,assistantMsg]}));
+      while(true){const{done,value}=await reader.read();if(done)break;const text=decoder.decode(value,{stream:true});const lines=text.split('\n');
+        for(const line of lines){if(line.startsWith('data: ')){const d=line.slice(6).trim();if(d==='[DONE]')continue;try{const p=JSON.parse(d);if(p.content){assistantContent+=p.content;set(s=>{const m=[...s.messages];const l=m[m.length-1];if(l.role==='assistant')m[m.length-1]={...l,content:assistantContent};return{messages:m};});}}catch{}}}
+      }
+    } catch{set(s=>({messages:[...s.messages,{id:Date.now()+2,role:'assistant',content:'❌ Erreur de connexion au serveur.',created_at:new Date().toISOString()}]}));}
+    finally{set({isStreaming:false});}
+  },
+
+  setSidebarOpen:(open)=>set({sidebarOpen:open}),
+  setCurrentView:(view)=>set({currentView:view}),
+  setMobileMenuOpen:(open)=>set({mobileMenuOpen:open}),
+}));
