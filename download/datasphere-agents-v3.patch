+    if key in store:
+        attempts, start = store[key]
+        if now - start > window:
+            store[key] = (1, now)
+        elif attempts >= max_attempts:
+            raise HTTPException(status_code=status.HTTP_429_TOO_MANY_REQUESTS, detail="Trop de tentatives. Réessayez plus tard.")
