+import json
+import os
+from typing import List, Optional
+from sqlalchemy.orm import Session
+from app.models import Document
+
+
+UPLOAD_DIR = os.path.join(os.path.dirname(os.path.dirname(os.path.dirname(__file__))), "uploads")
+os.makedirs(UPLOAD_DIR, exist_ok=True)
+
+
+def save_document(db: Session, filename: str, file_type: str, file_size: int, content: str, user_id: Optional[int] = None) -> Document:
+    chunks = create_chunks(content)
+    doc = Document(
+        filename=filename,
+        file_type=file_type,
+        file_size=file_size,
+        content=content,
+        chunks=json.dumps(chunks, ensure_ascii=False),
+        user_id=user_id,
+    )
+    db.add(doc)
+    db.commit()
+    db.refresh(doc)
+    return doc
+
+
+def create_chunks(text: str, chunk_size: int = 500, overlap: int = 50) -> List[str]:
+    if not text:
+        return []
+    paragraphs = [p.strip() for p in text.split("\n\n") if p.strip()]
+    chunks = []
+    current_chunk = ""
+    for para in paragraphs:
+        if len(current_chunk) + len(para) + 2 <= chunk_size:
+            current_chunk += ("\n\n" if current_chunk else "") + para
+        else:
+            if current_chunk:
+                chunks.append(current_chunk)
+            if len(para) > chunk_size:
+                sentences = para.replace(". ", ".\n").split("\n")
+                current_chunk = ""
+                for sent in sentences:
+                    if len(current_chunk) + len(sent) + 1 <= chunk_size:
+                        current_chunk += (" " if current_chunk else "") + sent
+                    else:
+                        if current_chunk:
+                            chunks.append(current_chunk)
+                        current_chunk = sent
+                if current_chunk:
+                    chunks.append(current_chunk)
+                current_chunk = ""
+            else:
+                current_chunk = para
+    if current_chunk:
+        chunks.append(current_chunk)
+    return chunks
+
+
+def query_documents(db: Session, query: str, document_ids: Optional[List[int]] = None) -> str:
+    docs = db.query(Document)
+    if document_ids:
+        docs = docs.filter(Document.id.in_(document_ids))
+    docs = docs.all()
+    if not docs:
+        return "Aucun document trouvé. Veuillez d'abord uploader des documents."
+    query_words = set(query.lower().split())
+    scored_chunks = []
+    for doc in docs:
+        chunks = json.loads(doc.chunks) if doc.chunks else []
+        for chunk in chunks:
+            chunk_words = set(chunk.lower().split())
+            score = len(query_words & chunk_words)
+            if score > 0:
+                scored_chunks.append((score, chunk, doc.filename))
+    if not scored_chunks:
+        context_parts = []
+        for doc in docs[:2]:
+            chunks = json.loads(doc.chunks) if doc.chunks else []
+            for chunk in chunks[:3]:
+                context_parts.append(f"[{doc.filename}]: {chunk}")
+        context = "\n\n".join(context_parts[:5])
+        return f"Contexte trouvé dans les documents :\n\n{context}"
+    scored_chunks.sort(key=lambda x: x[0], reverse=True)
+    context_parts = []
+    for score, chunk, filename in scored_chunks[:5]:
+        context_parts.append(f"[{filename}]: {chunk}")
+    return "\n\n".join(context_parts)
+
+
+def delete_document(db: Session, doc_id: int) -> bool:
+    doc = db.query(Document).filter(Document.id == doc_id).first()
+    if doc:
+        db.delete(doc)
+        db.commit()
+        return True
+    return False
