+// ─── Provider Configuration ──────────────────────────────────────────
+
+export type ProviderId = "openai" | "anthropic" | "groq" | "qwen" | "openrouter";
+
+export interface ProviderConfig {
+  id: ProviderId;
+  name: string;
+  baseUrl: string;
+  defaultModel: string;
+  models: string[];
+  icon: string;
+  color: string;
+}
+
+export const PROVIDERS: Record<ProviderId, ProviderConfig> = {
