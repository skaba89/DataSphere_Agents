+'use client';
+
+import { useEffect, useRef, useState, useCallback } from 'react';
+import { motion } from 'framer-motion';
+import { useAppStore } from '@/lib/store';
+import { toast } from 'sonner';
+import ReactMarkdown from 'react-markdown';
+import {
+  Globe,
+  Monitor,
+  Tablet,
+  Smartphone,
+  Send,
+  Square,
+  Copy,
+  Download,
+  Code2,
+  Eye,
