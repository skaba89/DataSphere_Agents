+if (process.env.NODE_ENV !== 'production') globalForPrisma.prisma = db
+
+// Graceful shutdown
+if (typeof process !== 'undefined') {
+  process.on('beforeExit', async () => {
+    await db.$disconnect()
+  })
+}
