+import { NextRequest, NextResponse } from "next/server";
+import { db } from "@/lib/db";
+import { verifyToken } from "@/lib/auth";
+import { decryptKey, PROVIDERS, ProviderId, chatCompletion } from "@/lib/ai-providers";
+
+// POST /api/apikeys/test — test connection to a provider
+export async function POST(request: NextRequest) {
+  try {
+    const authHeader = request.headers.get("authorization");
+    if (!authHeader?.startsWith("Bearer ")) {
+      return NextResponse.json({ error: "Non autorisé" }, { status: 401 });
+    }
+
+    const payload = await verifyToken(authHeader.slice(7));
+    if (!payload) {
+      return NextResponse.json({ error: "Token invalide" }, { status: 401 });
+    }
+
+    const body = await request.json();
+    const { provider } = body;
+
+    if (!provider) {
+      return NextResponse.json({ error: "Provider requis" }, { status: 400 });
+    }
+
+    // Get the user's API key for this provider
+    const record = await db.apiKey.findUnique({
+      where: { userId_provider: { userId: payload.userId, provider } },
+    });
+
+    if (!record || !record.isActive) {
+      return NextResponse.json(
+        { error: `Aucune clé API active pour ${PROVIDERS[provider as ProviderId]?.name || provider}` },
+        { status: 404 }
+      );
+    }
+
+    const apiKey = decryptKey(record.keyEnc);
+    const providerConfig = PROVIDERS[provider as ProviderId];
+
+    if (!providerConfig) {
+      return NextResponse.json({ error: "Provider invalide" }, { status: 400 });
+    }
+
+    // Make a minimal test API call
+    try {
+      const result = await chatCompletion({
+        provider: provider as ProviderId,
+        apiKey,
+        model: record.model || providerConfig.defaultModel,
