generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// CORE USER & AUTH
// ============================================

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String
  password          String
  role              String          @default("user") // "user", "admin", "super_admin"
  avatar            String?
  twoFactorSecret    String?         // TOTP secret (encrypted)
  twoFactorEnabled   Boolean         @default(false)
  twoFactorBackupCodes String?       // JSON array of hashed backup codes
  isActive          Boolean         @default(true) // Account active/suspended
  onboardingCompleted Boolean       @default(false) // Whether user completed onboarding wizard
  lastLoginAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  transactions      Transaction[]
  documents         Document[]
  conversations     Conversation[]
  sharedAgents      SharedAgent[]
  notifications     Notification[]
  aiApiKeys         AiProviderKey[]
  subscription      Subscription?
  usageEvents       UsageEvent[]
  organizationMembers OrganizationMember[]
  platformApiKeys   PlatformApiKey[]
  agentRatings      AgentRating[]
  auditLogs         AuditLog[]
  webhooks          Webhook[]
  workflows         Workflow[]
  prospects         Prospect[]
  marketInsights    MarketInsight[]
  customerHealths   CustomerHealth[]
  agentMemories     AgentMemory[]
  learningEvents    LearningEvent[]
}

// ============================================
// SAAS - PLANS & SUBSCRIPTIONS
// ============================================

model Plan {
  id                String   @id @default(cuid())
  name              String   @unique // "free", "pro", "enterprise"
  displayName       String   // "Gratuit", "Pro", "Enterprise"
  priceMonthly      Float    @default(0)  // Price in EUR/month
  priceYearly       Float    @default(0)  // Price in EUR/year
  currency          String   @default("eur")
  stripePriceId     String?  // Stripe Price ID for monthly
  stripePriceIdYearly String? // Stripe Price ID for yearly
  features          String   // JSON string of features list
  // Quota limits
  maxAgents         Int      @default(3)
  maxConversations  Int      @default(50)
  maxDocuments      Int      @default(5)
  maxTokensPerMonth Int      @default(100000) // 100k tokens
  maxTeamMembers    Int      @default(1)
  maxFileUploadMb   Int      @default(5)
  allowCustomAgents Boolean  @default(false)
  allowWebBuilder   Boolean  @default(true)
  allowApiAccess    Boolean  @default(false)
  allowPriority     Boolean  @default(false) // Priority AI responses
  allowWhiteLabel   Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions     Subscription[]
  organizations     Organization[]
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId            String
  plan              Plan     @relation(fields: [planId], references: [id])
  status            String   @default("active") // "active", "past_due", "canceled", "trialing"
  stripeCustomerId  String?  @unique
  stripeSubId       String?  @unique
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd  DateTime @default(now())
  cancelAtPeriodEnd Boolean  @default(false)
  trialEnd          DateTime?
  billingInterval   String   @default("monthly") // "monthly", "yearly"
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invoices          Invoice[]
}

model Invoice {
  id                String       @id @default(cuid())
  subscriptionId    String
  subscription      Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount            Float
  currency          String       @default("eur")
  status            String       @default("pending") // "pending", "paid", "failed", "refunded"
  stripeInvoiceId   String?      @unique
  stripeInvoiceUrl  String?      // Hosted invoice URL from Stripe
  paidAt            DateTime?
  createdAt         DateTime     @default(now())
}

// ============================================
// SAAS - USAGE METERING
// ============================================

model UsageEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType   String   // "chat_message", "image_gen", "webbuilder", "document_upload", "speech"
  tokensUsed  Int      @default(0)  // Approximate token count
  provider    String   @default("auto") // AI provider used
  agentId     String?
  metadata    String   @default("{}") // JSON metadata
  createdAt   DateTime @default(now())
}

// ============================================
// SAAS - ORGANIZATIONS / TEAMS
// ============================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  planId      String?
  plan        Plan?    @relation(fields: [planId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     OrganizationMember[]
}

model OrganizationMember {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String       @default("member") // "owner", "admin", "member"
  invitedAt       DateTime     @default(now())
  joinedAt        DateTime?

  @@unique([organizationId, userId])
}

// ============================================
// SAAS - PLATFORM API KEYS (for external consumers)
// ============================================

model PlatformApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // Label for the key
  keyHash     String   @unique // SHA-256 hash of the actual key
  keyPrefix   String   // First 8 chars for identification (e.g., "ds_live_")
  permissions String   @default("read") // JSON: ["read", "write", "admin"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// AI AGENTS & CONVERSATIONS
// ============================================

model Agent {
  id            String        @id @default(cuid())
  name          String
  description   String
  type          String
  systemPrompt  String
  icon          String        @default("Bot")
  color         String        @default("emerald")
  isDefault     Boolean       @default(false)
  creatorId     String?
  isTemplate    Boolean       @default(false) // True if this is a reusable template
  templateCategory String?    // Category for template marketplace
  tags          String        @default("[]") // JSON array of tags
  avgRating     Float         @default(0) // Average rating from users
  ratingCount   Int           @default(0) // Number of ratings
  totalConversations Int      @default(0) // Usage counter
  isActive      Boolean       @default(true) // Can be disabled by admin
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  conversations Conversation[]
  ratings       AgentRating[]
  tools         AgentTool[]
  memories      AgentMemory[]
  promptVersions PromptVersion[]
}

model Conversation {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  agentId     String
  agent       Agent        @relation(fields: [agentId], references: [id])
  title       String
  isPinned    Boolean      @default(false) // Pinned/favorite conversation
  isArchived  Boolean      @default(false) // Archived conversation
  tags        String       @default("[]") // JSON array of tags for search
  summary     String?      // AI-generated conversation summary
  messages    ChatMessage[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  model          String?      // AI model used for this response
  provider       String?      // AI provider used
  tokensUsed     Int          @default(0) // Token count for this message
  responseTime   Int          @default(0) // Response time in ms
  rating         Int?         // User rating 1-5 for this response
  createdAt      DateTime     @default(now())
}

// ============================================
// MARKETPLACE
// ============================================

model SharedAgent {
  id           String   @id @default(cuid())
  name         String
  description  String
  type         String
  systemPrompt String
  icon         String   @default("Bot")
  color        String   @default("emerald")
  creatorId    String
  creator      User     @relation(fields: [creatorId], references: [id])
  downloads    Int      @default(0)
  rating       Float    @default(0)
  ratingCount  Int      @default(0)
  tags         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================
// DOCUMENTS & TRANSACTIONS
// ============================================

model Document {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  filename  String
  content   String
  size      Int      @default(0)
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  phone     String
  status    String   @default("success")
  provider  String   @default("Mobile Money")
  createdAt DateTime @default(now())
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================
// AI PROVIDER KEYS (per-user encrypted)
// ============================================

model AiProviderKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   // "openai", "anthropic", "groq", "qwen", "openrouter"
  keyEnc    String   // encrypted API key
  model     String   @default("") // preferred model for this provider
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
}

// ============================================
// AGENT RATINGS & REVIEWS
// ============================================

model AgentRating {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5 stars
  review    String?  // Optional text review
  createdAt DateTime @default(now())

  @@unique([userId, agentId])
}

// ============================================
// AUDIT LOG (Admin compliance & tracking)
// ============================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // "user.login", "user.create", "agent.create", "admin.role_change", etc.
  entity    String?  // Target entity type (User, Agent, Conversation, etc.)
  entityId  String?  // Target entity ID
  details   String   @default("{}") // JSON details
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

// ============================================
// AI COMPARISON RESULTS
// ============================================

model ComparisonResult {
  id              String   @id @default(cuid())
  userId          String
  prompt          String   // The original prompt sent to all providers
  results         String   // JSON: [{provider, model, response, tokensUsed, responseTime, rating}]
  bestProvider    String?  // Auto-determined best result
  createdAt       DateTime @default(now())
}

// ============================================
// WEBHOOKS (External integrations)
// ============================================

model Webhook {
  id              String   @id @default(cuid())
  userId          String
  url             String
  secret          String   // HMAC secret for signing payloads
  events          String   // JSON array of event types
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastTriggeredAt DateTime?
  failureCount    Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]

  @@index([userId])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     String   // JSON payload
  statusCode  Int?
  response    String?
  success     Boolean
  createdAt   DateTime @default(now())
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

// ============================================
// WORKFLOWS & ORCHESTRATION
// ============================================

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  steps       String   // JSON array of step definitions
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  executions  WorkflowExecution[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  workflowId  String
  status      String   @default("pending") // pending, running, completed, failed
  currentStep Int      @default(0)
  input       String?  // JSON input data
  output      String?  // JSON output data
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

// ============================================
// AGENT TOOLS / FUNCTION CALLING
// ============================================

model AgentTool {
  id          String   @id @default(cuid())
  agentId     String
  name        String   // e.g. "web_search", "calculator", "code_executor"
  description String   // Description for the LLM
  parameters  String   // JSON schema of parameters
  type        String   @default("builtin") // builtin, custom
  isActive    Boolean  @default(true)
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, name])
  @@index([agentId])
}

// ============================================
// PROSPECTION & MARKET INTELLIGENCE
// ============================================

model Prospect {
  id          String   @id @default(cuid())
  userId      String
  company     String
  contactName String?
  email       String?
  phone       String?
  website     String?
  industry    String?
  size        String?   // startup, small, medium, large, enterprise
  status      String    @default("new") // new, contacted, qualified, proposal, negotiation, won, lost
  score       Float     @default(0) // Lead score 0-100
  source      String?   // manual, web_search, referral, import
  notes       String?
  tags        String?   // JSON array
  lastContactAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities  ProspectActivity[]

  @@index([userId])
  @@index([status])
  @@index([score])
}

model ProspectActivity {
  id          String   @id @default(cuid())
  prospectId  String
  type        String   // call, email, meeting, note, status_change, score_change
  content     String
  createdAt   DateTime @default(now())
  prospect    Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
}

model MarketInsight {
  id          String   @id @default(cuid())
  userId      String
  type        String   // trend, competitor, opportunity, alert
  title       String
  summary     String
  data        String?  // JSON detailed data
  source      String?  // web_search, ai_analysis, user_input
  relevance   Float    @default(0.5) // 0-1
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model CustomerHealth {
  id              String   @id @default(cuid())
  userId          String
  customerEmail   String
  healthScore     Float    @default(50) // 0-100
  churnRisk       String   @default("low") // low, medium, high, critical
  engagementLevel String   @default("moderate") // dormant, low, moderate, high, power
  lastActivityAt  DateTime?
  metrics         String?  // JSON: login frequency, feature usage, support tickets
  recommendations String?  // JSON: AI-generated recommendations
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, customerEmail])
  @@index([userId])
  @@index([churnRisk])
}

// ============================================
// AGENT MEMORY & SELF-LEARNING
// ============================================

model AgentMemory {
  id           String    @id @default(cuid())
  agentId      String
  userId       String
  category     String    // fact, preference, pattern, correction, context
  key          String    // Short identifier
  content      String    // The memory content
  confidence   Float     @default(1.0) // 0.0-1.0 confidence score
  source       String    @default("interaction") // interaction, feedback, system, learned
  accessCount  Int       @default(0)
  lastAccessed DateTime?
  expiresAt    DateTime? // Optional expiration for temporary memories
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  agent        Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agentId, userId, key])
  @@index([agentId, userId])
  @@index([category])
}

model LearningEvent {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  eventType String   // prompt_adjusted, preference_learned, correction_applied, pattern_detected, feedback_received
  data      String   // JSON event data
  impact    Float    @default(0) // -1.0 to 1.0 impact score
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentId])
  @@index([createdAt])
}

model PromptVersion {
  id           String   @id @default(cuid())
  agentId      String
  version      Int
  systemPrompt String
  performance  Float?   // 0-100 performance score based on user feedback
  messageCount Int      @default(0)
  avgRating    Float?   // Average user rating for this version
  createdAt    DateTime @default(now())
  isActive     Boolean  @default(true)
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, version])
  @@index([agentId])
}
